# Local development only — loaded by the Hono API server when running `pnpm dev:api` or `pnpm dev`.
# Copy this file to .env and fill in the values.
# Do NOT use this file for Docker/production. Use the .env at the repo root instead.

# API Configuration
API_BASE_URL=http://localhost:3000
PORT=3000

# Upload Configuration
# MAX_FILE_SIZE_MB=50

# Cloud storage (optional — leave empty to use local storage)
# STORAGE_PROVIDER=
# STORAGE_REGION=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_BUCKET_NAME=
# STORAGE_PUBLIC_URL=
# STORAGE_ENDPOINT=