# Local development only — loaded by Next.js when running `pnpm dev:web` or `pnpm dev`.
# Copy this file to .env and fill in the values.
# Do NOT use this file for Docker/production. Use the .env at the repo root instead.

NODE_ENV=development

# BETTER_AUTH_SECRET is auto-generated in Docker. Override here if needed:
BETTER_AUTH_SECRET=your-custom-secret-key-here
BETTER_AUTH_URL=http://localhost:3001

# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000