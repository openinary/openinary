{
  "name": "@openinary/core",
  "version": "1.0.0",
  "description": "Openinary's media transformation engine and route handlers (image/video processing, storage, job queue) as a standalone, embeddable package.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/openinary/openinary",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/add-js-extensions.cjs",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts')"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.855.0",
    "@aws-sdk/s3-request-presigner": "^3.855.0",
    "@webtoon/psd": "^0.4.0",
    "better-sqlite3": "^11.8.1",
    "fflate": "^0.8.3",
    "fluent-ffmpeg": "^2.1.2",
    "hono": "^4.12.30",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^24.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.2"
  }
}
