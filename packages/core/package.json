{
  "name": "@openinary/core",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/add-js-extensions.cjs",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts')"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.855.0",
    "@aws-sdk/s3-request-presigner": "^3.855.0",
    "@webtoon/psd": "^0.4.0",
    "better-sqlite3": "^11.8.1",
    "fflate": "^0.8.3",
    "fluent-ffmpeg": "^2.1.2",
    "hono": "^4.12.30",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "shared": "workspace:*",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^24.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.2"
  }
}
