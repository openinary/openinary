{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/utils": ["./src/stubs/utils.ts"],
      "@/components/ui/button": ["./src/stubs/button.tsx"],
      "@/components/ui/progress": ["./src/stubs/progress.tsx"],
      "@/components/openinary/*": ["./src/file-uploader/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
